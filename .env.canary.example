# KBTC Canary Environment — Demo live-path validation
# Copy to .env.canary and fill in values. NEVER commit .env.canary to git.
#
# PURPOSE: Runs the EXACT same live code path as production, but against
# Kalshi's demo environment with a small bankroll. Used to validate orphan
# handling, reconciliation, and settlement logic without risking real capital.
#
# SAFETY: The canary_up.sh script refuses to start if KALSHI_ENV != demo.

# ── Kalshi API (MUST be demo) ────────────────────────────────────────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
KALSHI_ENV=demo

# ── Canary Database ─────────────────────────────────────────────────────────
CANARY_POSTGRES_DB=kbtc_canary
CANARY_POSTGRES_USER=kalshi
CANARY_POSTGRES_PASSWORD=kalshi_canary_secret
DATABASE_URL=postgresql://kalshi:kalshi_canary_secret@canary-db:5432/kbtc_canary

# ── Bot Configuration ───────────────────────────────────────────────────────
BOT_ENV=production
MARKET=BTC
TRADING_MODE=live
INITIAL_BANKROLL=100.00
LOG_LEVEL=INFO

# ── Canary Identifier (for logs/alerts) ─────────────────────────────────────
CANARY_MODE=true
CANARY_INSTANCE_ID=canary-01

# ── OBI Strategy ────────────────────────────────────────────────────────────
OBI_DEPTH_LEVELS=10
OBI_LONG_THRESHOLD=0.65
OBI_SHORT_THRESHOLD=0.35
OBI_CONSECUTIVE_READINGS=3
MIN_BOOK_VOLUME=1000

# ── ROC Strategy ────────────────────────────────────────────────────────────
ROC_LOOKBACK=3
ROC_LONG_THRESHOLD=0.4
ROC_SHORT_THRESHOLD=-0.4
ROC_MAX_CAP=2.5

# ── ATR Regime Filter ──────────────────────────────────────────────────────
ATR_PERIOD=14
ATR_LOW_THRESHOLD=0.15
ATR_HIGH_THRESHOLD=0.50

# ── Spread Divergence Modifier ─────────────────────────────────────────────
SD_ENABLED=true
SD_BASELINE_WINDOW=60
SD_WIDE_THRESHOLD=0.40
SD_TIGHT_THRESHOLD=-0.20
SD_MIN_HISTORY=20
SD_STALENESS_SEC=90

# ── ROC LOW Conviction Activation (per-lane; keep false in canary) ─────────
ROC_LOW_CONVICTION_PAPER_ENABLED=false
ROC_LOW_CONVICTION_LIVE_ENABLED=false

# ── Expiry Race Guard (BUG-028) ───────────────────────────────────────────
MIN_SECONDS_TO_EXPIRY=120
EXPIRY_MARKET_STATUS_CHECK_ENABLED=true

# ── Phase 2 Live Retry Widening (defaults preserve legacy behavior) ───────
# Canary intentionally inherits production-default behavior here so the
# canary-vs-prod comparison stays valid while widening is being calibrated.
EXPIRY_RETRY_MAX_ATTEMPTS=3
EXPIRY_RETRY_BACKOFF_BASE_SEC=2.0
EXPIRY_RETRY_FIRST_ATTEMPT_YES_FLOOR_CENTS=1
EXPIRY_RETRY_FIRST_ATTEMPT_NO_FLOOR_CENTS=1
EXPIRY_RETRY_WIDEN_STEP_CENTS=0
EXPIRY_RETRY_FINAL_ATTEMPT_MAX_AGGRESSIVE=true

# ── Risk Management (small for canary) ──────────────────────────────────────
RISK_PER_TRADE_PCT=0.02
DAILY_LOSS_LIMIT_PCT=0.10
WEEKLY_LOSS_LIMIT_PCT=0.25
MAX_DRAWDOWN_PCT=0.30
STOP_LOSS_PCT=0.02
MAX_LIVE_CONTRACTS=5
MIN_SHORT_ENTRY_PRICE=20.0
SHORT_TREND_LOOKBACK_CANDLES=4
SHORT_TREND_SOFTEN_RISE_PCT=0.20
SHORT_TREND_BLOCK_RISE_PCT=0.35

# ── Discord (optional — send canary alerts to a separate channel) ───────────
DISCORD_TRADES_WEBHOOK=
DISCORD_RISK_WEBHOOK=
DISCORD_HEARTBEAT_WEBHOOK=
DISCORD_ERRORS_WEBHOOK=

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:8100

# ── Dashboard API Auth ──────────────────────────────────────────────────────
# Bearer token required for state-mutating endpoints. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_API_TOKEN=
