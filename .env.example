# KBTC Trading Bot — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Kalshi API ─────────────────────────────────────────────────────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
KALSHI_ENV=demo                    # demo | prod

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=kbtc
POSTGRES_USER=kalshi
POSTGRES_PASSWORD=kalshi_secret
DATABASE_URL=postgresql://kalshi:kalshi_secret@db:5432/kbtc

# ── Bot Configuration ─────────────────────────────────────────────────────
BOT_ENV=development                # development | production
MARKET=BTC                         # BTC only for now
TRADING_MODE=paper                 # paper | live
INITIAL_BANKROLL=1000.00
LOG_LEVEL=DEBUG

# ── OBI Strategy ──────────────────────────────────────────────────────────
OBI_DEPTH_LEVELS=10
OBI_LONG_THRESHOLD=0.65
OBI_SHORT_THRESHOLD=0.35
OBI_CONSECUTIVE_READINGS=2
MIN_BOOK_VOLUME=1000

# ── ROC Strategy ──────────────────────────────────────────────────────────
ROC_LOOKBACK=3
ROC_LONG_THRESHOLD=0.4
ROC_SHORT_THRESHOLD=-0.4
ROC_MAX_CAP=2.5

# ── ATR Regime Filter ─────────────────────────────────────────────────────
ATR_PERIOD=14
ATR_LOW_THRESHOLD=0.15
ATR_HIGH_THRESHOLD=0.50

# ── Spread Divergence Modifier ────────────────────────────────────────────
# Post-resolver conviction modifier based on bid-ask spread vs rolling baseline.
# MEDIUM regime only. See .cursor/rules/spread-div.mdc
SD_ENABLED=true
SD_BASELINE_WINDOW=60                    # snapshots in rolling median (~30 min at 30s refresh)
SD_WIDE_THRESHOLD=0.40                   # spread 40% above baseline -> WIDE -> downgrade
SD_TIGHT_THRESHOLD=-0.20                 # spread 20% below baseline -> TIGHT -> upgrade
SD_MIN_HISTORY=20                        # minimum history before modifier fires
SD_STALENESS_SEC=90                      # stale spread feed -> safe NORMAL default

# ── ROC LOW Conviction Activation (per-lane) ──────────────────────────────
# Controls whether Conviction.LOW (ROC-only, OBI neutral) trades can fire.
# Flip paper=true first, validate 48h vs spec gates, THEN flip live=true.
ROC_LOW_CONVICTION_PAPER_ENABLED=false
ROC_LOW_CONVICTION_LIVE_ENABLED=false

# ── Expiry Race Guard (BUG-028) ───────────────────────────────────────────
# Refuse to enter when the active contract is within this many seconds of
# close, OR when state.time_remaining_sec is None (ticker just rotated and
# no `ticker` WS event has populated expiry_time yet -- the actual root
# cause of every observed EXPIRY_409_SETTLED trade prior to the fix).
MIN_SECONDS_TO_EXPIRY=120
# Layer-2 backstop: right before placing an entry order, fetch the market
# and abort if Kalshi reports anything other than `open`. Catches the
# residual ~10-100ms race between decision and order placement. ON by
# default; flip OFF only if the extra REST hop is shown to add more
# latency cost than the EXPIRY_409 trades it prevents.
EXPIRY_MARKET_STATUS_CHECK_ENABLED=true

# ── Risk Management ───────────────────────────────────────────────────────
RISK_PER_TRADE_PCT=0.02
DAILY_LOSS_LIMIT_PCT=0.06
WEEKLY_LOSS_LIMIT_PCT=0.15
MAX_DRAWDOWN_PCT=0.20
STOP_LOSS_PCT=0.02

# ── Discord Notifications ─────────────────────────────────────────────────
DISCORD_TRADES_WEBHOOK=
DISCORD_RISK_WEBHOOK=
DISCORD_HEARTBEAT_WEBHOOK=
DISCORD_ERRORS_WEBHOOK=
DISCORD_ATTRIBUTION_WEBHOOK=
DISCORD_LIVE_TRADES_WEBHOOK=

# ── Tuning ────────────────────────────────────────────────────────────────
TUNING_INTERVAL_HOURS=6

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Dashboard API Auth ────────────────────────────────────────────────────
# Bearer token required for state-mutating endpoints (trading-mode, emergency-stop,
# close-all-exchange-positions, reset-drawdown, trade-limit, trading-pause,
# DELETE /param-overrides). Leave blank in dev to disable auth entirely.
# REQUIRED in production. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
DASHBOARD_API_TOKEN=

# ── Historical Data Sync ─────────────────────────────────────────────────
HISTORICAL_SYNC_ENABLED=true

# Predexon (L2 OB bootstrap) — get key at predexon.com
PREDEXON_API_KEY=
PREDEXON_BASE_URL=https://api.predexon.com/v2
PREDEXON_BOOTSTRAP_DAYS=90
PREDEXON_BOOTSTRAP_INTERVAL_SEC=600

# Kalshi settlement backfill
KALSHI_SETTLEMENT_SYNC_DAYS=90
KALSHI_SETTLEMENT_SYNC_INTERVAL_SEC=3600

# Kalshi public trades + TFI
KALSHI_TRADES_SYNC_DAYS=30
KALSHI_TRADES_SYNC_INTERVAL_SEC=300
TFI_WINDOW_MINUTES=15
TFI_DISAGREE_THRESHOLD=0.1
TFI_CONVICTION_ENABLED=true

# ── Edge Guards ───────────────────────────────────────────────────────
SHORT_MIN_ENTRY_PRICE=25
LONG_MAX_ENTRY_PRICE=60
SHORT_SIZE_MULT=0.7
SHORT_SETTLEMENT_GUARD_SEC=300
# Short entries inside the contract close window are blocked at the price-guard
# layer. Paper attribution on 21d showed shorts entered with <13 min to close
# were 0-30% WR and lost $6.6k net. See docs/runbooks/live-edge-filters.md.
SHORT_MIN_SECONDS_TO_EXPIRY=780

# ── Live Edge Profile ────────────────────────────────────────────────
# Restricts the LIVE lane to the validated edge subset from paper attribution.
# Paper lane is NEVER affected (continues full strategy for data collection).
# See backend/filters/edge_profile.py for the empirical justification of each default.
EDGE_LIVE_PROFILE_ENABLED=false
EDGE_LIVE_LONG_ONLY=true
EDGE_LIVE_BLOCK_LOW_CONVICTION=true
EDGE_LIVE_MAX_ENTRY_PRICE=30.0
EDGE_LIVE_AGREEMENT_OVERRIDES_PRICE_CAP=true
EDGE_LIVE_ALLOWED_DRIVERS=OBI,OBI+ROC,ROC
EDGE_LIVE_BLOCKED_HOURS_UTC=0,1,2,3,4,5,6,7
# ROC-contradiction veto for NORMAL-conviction shorts. NORMAL shorts with
# raw 5-bar ROC <= threshold get blocked. Calibrated 2026-05-02 from a
# 14-day paper window: this cohort lost -$120/trade across 103 trades at
# 40% WR while every other ROC bucket was breakeven-to-profitable.
# Setting to 0.0 (or any non-negative value) disables the gate entirely.
# HIGH-conviction shorts always override this veto.
EDGE_LIVE_SHORT_BLOCK_NEGATIVE_ROC_THRESHOLD=-0.05

# ── Supervised Live-Trade Cap ────────────────────────────────────────
# After this many completed live round-trips, PositionManager.can_enter
# returns False until the operator hits POST /api/trade-limit {"reset": true}.
# 0 = unlimited. Default 20 covers a full UTC day of quarter-hour sessions
# (long+short) without supervised resets while BUG-031 reconciliation and
# the new EDGE_LIVE_SHORT_BLOCK_NEGATIVE_ROC_THRESHOLD gate stay verified.
LIVE_TRADE_LIMIT=20

# BUG-032 (2026-05-04). EXPIRY_GUARD trigger window in seconds. Old
# hardcoded value was 60s, which was the single biggest contributor
# to today's orphan losses: a Kalshi exit-order round-trip can take
# 18+ seconds during pre-close volatility, and the coordinator's 3
# retries with 2s + 4s backoff burn through 60s easily. Default 180s
# gives the worst-case retry sequence enough headroom to complete
# before the contract closes on the exchange.
EXPIRY_GUARD_TRIGGER_SEC=180
# BUG-032 layer 2: shorter fill-poll timeout for EXPIRY_GUARD /
# SHORT_SETTLEMENT_GUARD exits only. The 15s default is right for
# normal exits but is too long when racing the close. Default 5s.
EXPIRY_GUARD_FILL_POLL_TIMEOUT_SEC=5.0

# Phase 2 (Expiry Exit Reliability, 2026-05-04). Live retry widening for
# EXPIRY_GUARD / SHORT_SETTLEMENT_GUARD only. The current live exit path
# sends market sells with yes_price=1 (max aggressive), so retries did
# not change exchange execution. The widening config lets attempt 0 try
# a tighter floor (closer to mid) and step down to the existing
# max-aggressive behavior on the final attempt, with the final attempt
# pinned to 1-cent floor when *_FINAL_ATTEMPT_MAX_AGGRESSIVE=true.
#
# Defaults below preserve legacy behavior exactly: attempt 0 already
# uses the 1-cent floor, so retries never change order prices unless
# the operator opts in. See docs/runbooks/live-edge-filters.md for the
# rollout playbook.
EXPIRY_RETRY_MAX_ATTEMPTS=3
EXPIRY_RETRY_BACKOFF_BASE_SEC=2.0
EXPIRY_RETRY_MAX_BACKOFF_SEC=8.0
# Per-attempt floor for the YES leg of a long exit (cents). 1 = current
# (max aggressive). Setting to e.g. 30 means attempt 0 only fills if the
# YES book has a bid ≥ 30c; subsequent attempts widen by
# EXPIRY_RETRY_WIDEN_STEP_CENTS until the final-attempt floor.
EXPIRY_RETRY_FIRST_ATTEMPT_YES_FLOOR_CENTS=1
EXPIRY_RETRY_FIRST_ATTEMPT_NO_FLOOR_CENTS=1
# Cents to widen (lower for long, raise for short) per retry attempt.
# 0 = no widening, all attempts share the same floor.
EXPIRY_RETRY_WIDEN_STEP_CENTS=0
# When true, the FINAL retry always uses the 1-cent floor regardless of
# the computed widen schedule. Safety rail required by BUG-032; do not
# disable in production unless you understand exactly why.
EXPIRY_RETRY_FINAL_ATTEMPT_MAX_AGGRESSIVE=true

# Phase 3 (Expiry Exit Reliability, 2026-05-04): pre-expiry passive
# limit ladder. OPT-IN, default OFF in production. When enabled, the
# coordinator places passive limit exits a few cents inside the
# executable side BEFORE the EXPIRY_GUARD trigger fires, polls briefly
# for fills, cancels/steps if no fill, and ALWAYS falls back to the
# standard EXPIRY_GUARD path when the time budget runs out. Designed
# to harvest better fills near close without ever extending the
# orphan window.
#
# Rollout discipline: enable in paper first, observe diagnostics for
# at least one week, then enable in live under a tight live_trade_limit.
# See docs/runbooks/live-edge-filters.md for the full playbook.
LADDER_ENABLED_PAPER=false
LADDER_ENABLED_LIVE=false
# When the contract has this many seconds to expiry, the ladder is
# allowed to start. MUST be greater than EXPIRY_GUARD_TRIGGER_SEC by
# at least LADDER_TOTAL_BUDGET_SEC so the ladder always finishes
# before the guard fires.
LADDER_START_TRIGGER_SEC=240
# Total time budget across all rungs. After this many seconds, the
# ladder yields to the EXPIRY_GUARD path even if no fills occurred.
LADDER_TOTAL_BUDGET_SEC=50
# Progressively aggressive rungs. Rung 0 is the tightest
# (operator-favorable), subsequent rungs widen.
LADDER_RUNG_COUNT=3
LADDER_RUNG_FIRST_OFFSET_CENTS=5
LADDER_RUNG_STEP_CENTS=3
# Per-rung poll/cancel timeout. After this many seconds without a fill,
# cancel the rung and step to the next.
LADDER_RUNG_TIMEOUT_SEC=8.0
# Restart safety: when true, PositionManager cancels any resting
# ladder-tagged orders on startup and falls through to standard
# reconciliation. Default false = trust the existing reconciliation
# path. Only enable after verifying on demo.
LADDER_CANCEL_ON_RESTART=false

# BUG-032 (2026-05-04, follow-up #2). Bounded background-task queue
# size for fire-and-forget persists. The first attempt at fixing the
# restart loop bumped this from 64 → 256 — that made things worse, as
# 256 queued tasks could each pin a MarketState reference and push RSS
# over the 1.8 GB container limit (SIGKILL in ~2 min). The real fix
# was in coordinator.py: snapshot writes now eagerly serialize the
# order book in the calling task so the queued coroutine carries only
# small primitives, and the per-tick dashboard broadcast is throttled
# to 5 Hz. With both, 96 is comfortably enough headroom.
BG_PERSIST_MAX=96

# When true, the coordinator flips trading_paused="paused" after every
# live exit and the operator must manually unpause via the dashboard
# before the next live entry can fire. Default false — live trades fire
# continuously until the LIVE_TRADE_LIMIT cap or an operator pause hits.
SUPERVISED_AUTO_PAUSE=false
