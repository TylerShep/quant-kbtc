# KBTC Trading Bot — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Kalshi API ─────────────────────────────────────────────────────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=kalshi_private_key.pem
KALSHI_ENV=demo                    # demo | prod

# ── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=kbtc
POSTGRES_USER=kalshi
POSTGRES_PASSWORD=kalshi_secret
DATABASE_URL=postgresql://kalshi:kalshi_secret@db:5432/kbtc

# ── Bot Configuration ─────────────────────────────────────────────────────
BOT_ENV=development                # development | production
MARKET=BTC                         # BTC only for now
TRADING_MODE=paper                 # paper | live
INITIAL_BANKROLL=1000.00
LOG_LEVEL=DEBUG

# ── OBI Strategy ──────────────────────────────────────────────────────────
OBI_DEPTH_LEVELS=10
OBI_LONG_THRESHOLD=0.65
OBI_SHORT_THRESHOLD=0.35
OBI_CONSECUTIVE_READINGS=2
MIN_BOOK_VOLUME=1000

# ── ROC Strategy ──────────────────────────────────────────────────────────
ROC_LOOKBACK=3
ROC_LONG_THRESHOLD=0.4
ROC_SHORT_THRESHOLD=-0.4
ROC_MAX_CAP=2.5

# ── ATR Regime Filter ─────────────────────────────────────────────────────
ATR_PERIOD=14
ATR_LOW_THRESHOLD=0.15
ATR_HIGH_THRESHOLD=0.50

# ── Risk Management ───────────────────────────────────────────────────────
RISK_PER_TRADE_PCT=0.02
DAILY_LOSS_LIMIT_PCT=0.06
WEEKLY_LOSS_LIMIT_PCT=0.15
MAX_DRAWDOWN_PCT=0.20
STOP_LOSS_PCT=0.02

# ── Discord Notifications ─────────────────────────────────────────────────
DISCORD_TRADES_WEBHOOK=
DISCORD_RISK_WEBHOOK=
DISCORD_HEARTBEAT_WEBHOOK=
DISCORD_ERRORS_WEBHOOK=
DISCORD_ATTRIBUTION_WEBHOOK=

# ── Tuning ────────────────────────────────────────────────────────────────
TUNING_INTERVAL_HOURS=6

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
