# QA / Simulation Engineer

## Role Purpose
The QA/Simulation Engineer ensures the strategy works in the real world, not just on paper. Builds the paper trading environment that simulates realistic market conditions — including fill delays, partial fills, and data latency — so gaps between backtest and live performance are caught before real money is at risk.

## Primary Responsibilities
- Build and maintain the paper trading simulation environment
- Model realistic Kalshi fill mechanics (latency, partial fills, thin books)
- Write and maintain the regression test suite run before every deployment
- Validate that backtest results match live performance within acceptable tolerance
- Build a mock Kalshi API for unit and integration testing
- Flag unrealistic backtest assumptions and quantify their impact

## Paper Trading Environment
```python
# simulation/paper_trader.py
# Simulates live trading without real money, using live Kalshi data

class PaperTrader:
    """
    Subscribes to live Kalshi WebSocket and runs strategy exactly as production.
    Orders are simulated using realistic fill model instead of hitting the real API.
    """

    def __init__(self, strategy, fill_model: FillModel, initial_bankroll: float = 10000):
        self.strategy      = strategy
        self.fill_model    = fill_model
        self.bankroll      = initial_bankroll
        self.position      = None
        self.trade_log     = []

    async def on_candle_close(self, candle, book):
        """Same logic as production bot — only order execution is simulated."""
        regime = self.atr_filter.update(candle.high, candle.low, candle.close)

        if self.position:
            exit_signal = self.strategy.check_exit(self.position, candle, regime)
            if exit_signal:
                fill = await self.fill_model.simulate_exit(self.position, book)
                pnl  = self._calc_pnl(self.position, fill.price)
                self._record_trade(exit_signal.reason, pnl)
                self.bankroll += pnl
                self.position = None

        if not self.position:
            signal = self.strategy.evaluate_entry(candle, book, regime)
            if signal and self.risk_manager.can_trade():
                size = self.risk_manager.calculate_size(signal.confidence)
                fill = await self.fill_model.simulate_entry(signal, book, size)
                if fill.filled:
                    self.position = Position(
                        direction=signal.direction,
                        entry_price=fill.price,
                        contracts=fill.contracts,
                    )
```

## Fill Model (Realistic Simulation)
```python
import asyncio
import random

class RealisticFillModel:
    """
    Simulates Kalshi fill mechanics:
    - Latency: 50–250ms round-trip (varies by server load)
    - Partial fills: 15% of orders partially fill on thin books
    - Slippage: 1–2 cent slippage from quoted price
    - Rejection rate: ~2% of orders rejected (rate limits, out-of-range price)
    """

    FILL_LATENCY_MS   = (50, 250)     # min, max
    PARTIAL_FILL_RATE = 0.15          # 15% of limit orders partially fill
    SLIPPAGE_CENTS    = (0, 2)        # 0–2 cent slippage from mid
    REJECTION_RATE    = 0.02          # 2% rejection probability

    async def simulate_entry(self, signal: Signal, book: dict, size_dollars: float) -> FillResult:
        # Simulate network latency
        latency_ms = random.uniform(*self.FILL_LATENCY_MS)
        await asyncio.sleep(latency_ms / 1000)

        # Simulate rejection
        if random.random() < self.REJECTION_RATE:
            return FillResult(filled=False, reason="SIMULATED_REJECTION")

        # Calculate fill price with slippage
        if signal.direction == "long":
            best_ask    = book["asks"][0]["price"]
            fill_price  = best_ask + random.randint(*self.SLIPPAGE_CENTS)
        else:
            best_bid    = book["bids"][0]["price"]
            fill_price  = best_bid - random.randint(*self.SLIPPAGE_CENTS)

        # Simulate partial fill on thin books
        contracts   = int(size_dollars / (fill_price / 100))
        if random.random() < self.PARTIAL_FILL_RATE:
            fill_ratio  = random.uniform(0.4, 0.9)
            contracts   = max(1, int(contracts * fill_ratio))

        return FillResult(
            filled=True,
            price=fill_price,
            contracts=contracts,
            latency_ms=latency_ms,
        )
```

## Mock Kalshi API (for Unit/Integration Tests)
```python
# tests/mocks/mock_kalshi.py
from unittest.mock import AsyncMock
import json

class MockKalshiClient:
    """
    Drop-in replacement for KalshiClient in tests.
    Returns configurable canned responses.
    """
    def __init__(self):
        self.orders = {}
        self.order_counter = 0
        self._order_book = self._default_book()

    async def place_order(self, ticker, side, contracts, price, order_type="limit"):
        self.order_counter += 1
        order_id = f"mock-order-{self.order_counter}"
        order = {
            "order_id": order_id,
            "status":   "filled",         # Default to immediate fill in tests
            "fill_price": price,
            "contracts": contracts,
        }
        self.orders[order_id] = order
        return MockOrder(**order)

    async def get_orderbook(self, ticker, depth=10):
        return self._order_book

    def set_order_book(self, bids, asks):
        """Test helper: inject a specific order book scenario."""
        self._order_book = {"bids": bids, "asks": asks}

    def simulate_thin_book(self):
        """Test helper: inject a thin book that should suppress OBI signals."""
        self.set_order_book(
            bids=[{"price": 50, "size": 10}],
            asks=[{"price": 52, "size": 10}],
        )

    def _default_book(self):
        return {
            "bids": [{"price": 50 - i, "size": 100 + i*10} for i in range(10)],
            "asks": [{"price": 51 + i, "size": 100 + i*10} for i in range(10)],
        }
