        mock_kalshi.set_order_book(strong_long_book)
        signal = obi_strategy.evaluate(mock_kalshi.get_orderbook(), regime="HIGH")
        assert signal is None

    def test_roc_does_not_fire_in_low_regime(self):
        """ROC momentum should be suppressed in LOW volatility."""
        candles = build_trending_candles(roc=0.8)
        signal  = roc_strategy.evaluate(candles, regime="LOW")
        assert signal is None

    def test_conflicting_signals_produce_no_trade(self):
        """OBI long + ROC short should never result in a trade."""
        signal = coordinator.evaluate(obi_direction="long", roc_direction="short")
        assert signal is None

    def test_stop_loss_triggers_correctly(self, paper_trader):
        """Position must close when price moves against entry by stop_loss_pct."""
        paper_trader.enter_long_at(price=51)
        adverse_candle = Candle(close=49.0)   # ~4% adverse move
        paper_trader.on_candle_close(adverse_candle)
        assert paper_trader.position is None
        assert paper_trader.last_exit_reason == "STOP_LOSS"

    def test_expiry_risk_exits_in_final_3_minutes(self, paper_trader):
        """Position must close automatically when contract expiry < 3 min."""
        paper_trader.enter_long_at(price=51)
        paper_trader.set_time_until_expiry(minutes=2.5)
        paper_trader.on_candle_close(neutral_candle)
        assert paper_trader.position is None
        assert paper_trader.last_exit_reason == "CONTRACT_EXPIRY_RISK"
