```

## Core Event Loop Pattern
```python
import asyncio

async def main_loop():
    """
    Main bot loop. Processes one 15-min candle close at a time.
    Order of operations is strict — never reorder.
    """
    book_stream = OrderBookStream(on_update=handle_book_update)
    candle_feed = CandleFeed(interval="15m")

    async with asyncio.TaskGroup() as tg:
        tg.create_task(book_stream.connect())
        tg.create_task(candle_feed.run(on_close=handle_candle_close))

async def handle_candle_close(candle: Candle):
    """Called on each 15-minute candle close."""
    # 1. Update regime filter first — it gates everything
    regime = atr_filter.update(candle.high, candle.low, candle.close)

    # 2. Check open position exits before evaluating new entries
    if position_manager.has_open():
        exit_signal = coordinator.check_exit(position_manager.current, candle, regime)
        if exit_signal:
            await order_manager.close_position(exit_signal.reason)
            risk_manager.record_close(exit_signal.pnl)

    # 3. Evaluate entry signals if flat
    if not position_manager.has_open():
        if not risk_manager.can_trade():
            return
        signal = coordinator.evaluate_entry(candle, book_store.latest(), regime)
        if signal:
            size = risk_manager.calculate_size(signal.confidence)
            await order_manager.place(signal.direction, size)
            position_manager.record_entry(signal)

    # 4. Heartbeat for health monitoring
    state_store.write_heartbeat()
```

## Signal Coordinator (OBI + ROC Conflict Resolution)
```python
class SignalCoordinator:
    CONFIDENCE_MAP = {
        ("long",  "long"):    ("long",  "HIGH"),
        ("long",  "neutral"): ("long",  "NORMAL"),
        ("short", "short"):   ("short", "HIGH"),
        ("short", "neutral"): ("short", "NORMAL"),
        ("neutral", "long"):  ("long",  "LOW"),
        ("neutral", "short"): ("short", "LOW"),
        ("long",  "short"):   (None,    None),   # Conflict — no trade
        ("short", "long"):    (None,    None),   # Conflict — no trade
        ("neutral", "neutral"): (None,  None),  # No signal
    }

    def evaluate_entry(self, candle, book, regime) -> Signal | None:
        obi_dir = self.obi.evaluate(book, regime)
        roc_dir = self.roc.evaluate(candle, regime)
        direction, confidence = self.CONFIDENCE_MAP.get(
            (obi_dir, roc_dir), (None, None)
        )
        if direction is None:
            return None
        return Signal(direction=direction, confidence=confidence)
```

## Implementation Standards
```python
# All strategy parameters must come from config — never hardcoded
from config.settings import OBI_LONG_THRESHOLD, ROC_LOOKBACK

# All public functions must have type hints
def calculate_obi(bids: list[dict], asks: list[dict], depth: int = 10) -> float: ...

# All modules must handle exceptions without crashing the loop
try:
    signal = coordinator.evaluate_entry(candle, book, regime)
except Exception as e:
    logger.error("Signal evaluation failed", exc_info=e)
    return  # Skip this candle, keep running

# All trade actions must be logged before and after
logger.info("ENTRY_ATTEMPT", direction=signal.direction, size=size)
result = await order_manager.place(signal.direction, size)
logger.info("ENTRY_RESULT", order_id=result.order_id, fill_price=result.fill)
```

## Latency Targets
```
Book update → OBI recalculation:     < 5ms
Candle close → signal evaluation:    < 50ms
Signal → order submitted:            < 200ms
Total round-trip (update → fill):    < 500ms
```

