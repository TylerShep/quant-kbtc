## Strategy Lifecycle Management
```python
# Criteria for graduating a strategy from research to live
STRATEGY_PROMOTION_CRITERIA = {
    "oos_sharpe":           1.0,    # Out-of-sample Sharpe must exceed 1.0
    "oos_win_rate":         0.52,   # Must beat coin flip on OOS data
    "oos_trade_count":      200,    # Statistical significance threshold
    "paper_weeks":          4,      # Minimum paper trading before micro live
    "max_drawdown_oos":     0.20,   # Must not exceed 20% drawdown in OOS
    "correlation_to_existing": 0.3, # New strategy must have low correlation to active ones
}

# Criteria for retiring a strategy
STRATEGY_RETIREMENT_CRITERIA = {
    "rolling_sharpe_30d":   0.0,    # 30-day Sharpe below zero → suspend
    "win_rate_drop_pp":     0.08,   # 8pp drop from backtest baseline → review
    "consecutive_losses":   8,      # 8 consecutive losses → pause for review
    "ic_floor":             0.02,   # Information coefficient below floor → retire
}

def evaluate_strategy_health(strategy_name: str, live_stats: dict, baseline: dict) -> str:
    """Returns: 'ACTIVE' | 'REVIEW' | 'SUSPEND' | 'RETIRE'"""
    if live_stats["rolling_sharpe_30d"] < 0:
        return "SUSPEND"
    if live_stats["win_rate"] < baseline["win_rate"] - STRATEGY_RETIREMENT_CRITERIA["win_rate_drop_pp"]:
        return "REVIEW"
    if live_stats["ic"] < STRATEGY_RETIREMENT_CRITERIA["ic_floor"]:
        return "RETIRE"
    return "ACTIVE"
```

## Portfolio Diversification Analysis
```python
import numpy as np

def analyze_strategy_correlation(strategy_returns: dict) -> np.ndarray:
    """
    Compute return correlations between strategies.
    Target: pairwise correlation < 0.3 for meaningful diversification.
    OBI and ROC are correlated by design (both trade BTC direction),
    which is why they act as confirmation, not independent strategies.
    """
    strategies = list(strategy_returns.keys())
    matrix = np.corrcoef([strategy_returns[s] for s in strategies])
    return dict(zip(strategies, matrix))

def portfolio_sharpe(combined_returns, periods_per_year=35040):
    return (np.mean(combined_returns) / np.std(combined_returns)) * np.sqrt(periods_per_year)
```

## Scaling Decision Framework
```python
# When to scale up bankroll exposure

def should_scale_up(live_stats: dict, current_stage: str) -> tuple[bool, str]:
    stage_config = DEPLOYMENT_STAGES[current_stage]
    next_stage   = get_next_stage(current_stage)
    if next_stage is None:
        return False, "Already at full deployment"

    weeks_live    = live_stats["weeks_live"]
    trades_live   = live_stats["total_trades"]
    sharpe_live   = live_stats["rolling_sharpe"]
    drawdown_live = live_stats["max_drawdown"]

    if weeks_live < stage_config["min_weeks"]:
        return False, f"Not enough weeks live ({weeks_live} / {stage_config['min_weeks']})"
    if trades_live < stage_config["min_trades"]:
        return False, f"Not enough trades ({trades_live} / {stage_config['min_trades']})"
    if sharpe_live < 1.0:
        return False, f"Sharpe too low ({sharpe_live:.2f})"
    if drawdown_live > 0.15:
        return False, f"Drawdown too high ({drawdown_live:.1%})"

    return True, f"Ready to scale to {next_stage}"
```

