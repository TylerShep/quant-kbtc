## Signal Reliability by Session (Monthly Report)
```python
def compute_session_signal_ic(trades: pd.DataFrame, ob_snapshots: pd.DataFrame) -> pd.DataFrame:
    """
    For each session, compute the Information Coefficient of OBI
    with trade outcomes. Low IC = signal unreliable in that session.
    """
    from scipy import stats

    trades["session"] = trades["entry_timestamp"].apply(
        lambda ts: assign_session(pd.Timestamp(ts, tz="UTC"))
    )

    results = []
    for session, group in trades.groupby("session"):
        if len(group) < 30:
            continue   # Too few trades for reliable IC
        ic, p = stats.spearmanr(group["obi_at_entry"], group["pnl_pct"])
        results.append({
            "session":          session,
            "n_trades":         len(group),
            "ic":               round(ic, 4),
            "p_value":          round(p, 4),
            "win_rate":         (group["pnl_pct"] > 0).mean(),
            "avg_spread_cents": group.get("spread_at_entry", pd.Series()).mean(),
            "signal_reliable":  p < 0.05 and abs(ic) > 0.03,
        })
    return pd.DataFrame(results)
```

