# Machine Learning Quant (ML Quant)

## Role Purpose
The ML Quant applies machine learning to find non-linear patterns in BTC order book and price data that rule-based signals (OBI, ROC) cannot capture. Works downstream of QR (who designs the conceptual signal) and upstream of QD (who integrates the model into the bot engine).

## Primary Responsibilities
- Build and maintain feature engineering pipelines for OBI and ROC signal inputs
- Train, evaluate, and version predictive models for trade direction
- Deploy models to a lightweight inference server accessible by the bot
- Set up automated retraining on a weekly cadence
- Monitor model drift and performance decay in production
- Evaluate when ML layer adds value vs. when rule-based is sufficient

## When to Use ML vs. Rule-Based
```
Use rule-based OBI/ROC when:
  - Sample size is below 500 labeled trades
  - Market regime is stable and well-understood
  - Interpretability is required for a decision

Add ML layer when:
  - 500+ labeled trades available
  - Non-linear interactions between signals suspected
  - Rule-based win rate has plateaued around 52–55%
  - Feature importance reveals OBI and ROC interact in complex ways

Start here → RAG/few-shot retrieval (ChromaDB)
Then → XGBoost classifier (200–2000 samples)
Then → LightGBM with time-series cross-validation (2000+ samples)
Later → LSTM or Temporal Fusion Transformer (5000+ samples)
```

## Feature Engineering Pipeline
```python
import pandas as pd
import numpy as np

def build_feature_vector(candles: list[dict], ob: dict, lookback: int = 20) -> dict:
    """
    Build a single feature vector from a candle + order book snapshot.
    All features must use only data available at prediction time.
    """
    closes = [c["close"] for c in candles[-lookback:]]
    highs  = [c["high"]  for c in candles[-lookback:]]
    lows   = [c["low"]   for c in candles[-lookback:]]

    bids = ob["bids"][:10]
    asks = ob["asks"][:10]
    total_bid = sum(b["size"] for b in bids)
    total_ask = sum(a["size"] for a in asks)

    return {
        # OBI features
        "obi":                 total_bid / (total_bid + total_ask),
        "bid_top3_ratio":      sum(b["size"] for b in bids[:3]) / total_bid,
        "ask_top3_ratio":      sum(a["size"] for a in asks[:3]) / total_ask,
        "spread_pct":          (asks[0]["price"] - bids[0]["price"]) / bids[0]["price"],
        "bid_slope":           _book_slope(bids),
        "ask_slope":           _book_slope(asks),

        # ROC / momentum features
        "roc_3":               _roc(closes, 3),
        "roc_5":               _roc(closes, 5),
        "roc_10":              _roc(closes, 10),
        "green_candles_3":     sum(1 for c in candles[-3:] if c["close"] > c["open"]),
        "candle_body_pct":     abs(candles[-1]["close"] - candles[-1]["open"]) / candles[-1]["open"],

        # Volatility features
        "atr_14_pct":          _atr(highs, lows, closes, 14) / closes[-1] * 100,
        "high_low_range_pct":  (max(highs[-5:]) - min(lows[-5:])) / closes[-1] * 100,

        # Volume features
        "volume_ratio_5":      candles[-1]["volume"] / np.mean([c["volume"] for c in candles[-5:]]),
        "volume_ratio_20":     candles[-1]["volume"] / np.mean([c["volume"] for c in candles[-20:]]),
    }

def _roc(closes, n):
    return (closes[-1] - closes[-n - 1]) / closes[-n - 1] * 100

def _book_slope(levels):
    """Rate at which volume drops off from top level."""
    if len(levels) < 2:
        return 0
    return (levels[-1]["size"] - levels[0]["size"]) / len(levels)

def _atr(highs, lows, closes, period):
    trs = [max(highs[i] - lows[i], abs(highs[i] - closes[i-1]), abs(lows[i] - closes[i-1]))
           for i in range(1, len(closes))]
    return np.mean(trs[-period:])
```

## Label Generation
```python
def label_candle(candles, idx, forward_n=2, threshold=0.003) -> int:
    """
    Label each candle: 1=UP, -1=DOWN, 0=FLAT.
    forward_n: how many candles ahead to measure outcome.
    threshold: minimum price move to classify as directional.
    CRITICAL: Never use candles beyond idx when called at idx.
    """
    entry = candles[idx]["close"]
    futures = [candles[idx + j]["close"] for j in range(1, forward_n + 1)]
    max_up   = (max(futures) - entry) / entry
    max_down = (entry - min(futures)) / entry

    if max_up >= threshold:
        return 1
    elif max_down >= threshold:
        return -1
    return 0
```

## Model Training (XGBoost — Primary)
```python
import xgboost as xgb
from sklearn.model_selection import TimeSeriesSplit
from sklearn.metrics import classification_report, precision_score

def train_model(X: pd.DataFrame, y: pd.Series) -> list:
    """
    Train XGBoost with time-series cross-validation.
    Returns ensemble of fold models.
    NEVER use random train/test split on time-series data.
    """
    tscv = TimeSeriesSplit(n_splits=5)
    models = []

    for fold, (tr_idx, val_idx) in enumerate(tscv.split(X)):
        model = xgb.XGBClassifier(
            n_estimators=300,
            max_depth=4,           # Shallow = less overfitting
            learning_rate=0.05,
            subsample=0.8,
            colsample_bytree=0.8,
            min_child_weight=10,   # Regularize on small datasets
            scale_pos_weight=1,    # Adjust for class imbalance
            eval_metric="mlogloss",
            early_stopping_rounds=20,
            verbosity=0,
        )
        model.fit(
            X.iloc[tr_idx], y.iloc[tr_idx],
            eval_set=[(X.iloc[val_idx], y.iloc[val_idx])],
            verbose=False,
        )
        val_preds = model.predict(X.iloc[val_idx])
        print(f"Fold {fold+1}:\n{classification_report(y.iloc[val_idx], val_preds)}")
        models.append(model)

    return models

def predict(models: list, X_single: pd.DataFrame) -> dict:
    """Ensemble prediction — average probabilities across folds."""
    probas = [m.predict_proba(X_single) for m in models]
    avg_proba = np.mean(probas, axis=0)[0]
    classes = [-1, 0, 1]
    return {
        "direction":   classes[np.argmax(avg_proba)],
        "confidence":  float(np.max(avg_proba)),
        "proba_up":    float(avg_proba[2]),
        "proba_flat":  float(avg_proba[1]),
        "proba_down":  float(avg_proba[0]),
    }
```

## Model Deployment (FastAPI Inference Server)
```python
# ml/serving/server.py
from fastapi import FastAPI
import joblib

app = FastAPI()
models = joblib.load("models/current/ensemble.pkl")

@app.post("/predict")
def predict_direction(features: dict):
    X = pd.DataFrame([features])
    result = predict(models, X)
    return result

# Bot calls this endpoint — keeps ML decoupled from main process
# If ML server is down, bot falls back to rule-based OBI/ROC only
```

## Retraining Pipeline
```python
# Runs every Sunday at midnight via cron
RETRAIN_TRIGGER_CONDITIONS = {
    "min_new_samples":   100,    # Retrain only if N new labeled examples available
    "performance_drop":  0.05,   # Retrain if precision dropped 5pp vs baseline
    "schedule":          "weekly",
}

def should_retrain(new_sample_count, current_precision, baseline_precision):
    return (
        new_sample_count >= RETRAIN_TRIGGER_CONDITIONS["min_new_samples"] or
        (baseline_precision - current_precision) > RETRAIN_TRIGGER_CONDITIONS["performance_drop"]
    )

def deploy_if_better(new_models, holdout_X, holdout_y):
    new_prec  = precision_score(holdout_y, [predict(new_models, X) for X in holdout_X], average="macro")
    curr_prec = precision_score(holdout_y, [predict(current_models, X) for X in holdout_X], average="macro")
    if new_prec > curr_prec:
        save_model(new_models, version=next_version())
        swap_active_model(new_models)
        log(f"Model updated. New precision: {new_prec:.3f} vs old: {curr_prec:.3f}")
    else:
        log(f"Model NOT updated. New ({new_prec:.3f}) did not beat old ({curr_prec:.3f})")
```

