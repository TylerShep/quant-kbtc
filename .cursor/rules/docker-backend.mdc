## Main Bot Dockerfile
```dockerfile
# services/bot/Dockerfile
FROM python:3.11-slim

# Security: run as non-root
RUN groupadd -r botuser && useradd -r -g botuser botuser

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first (layer caching)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY src/ ./src/

# Switch to non-root
RUN chown -R botuser:botuser /app
USER botuser

# Health check endpoint
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python src/healthcheck.py || exit 1

CMD ["python", "-u", "src/main.py"]
```

## Docker Compose — Development
```yaml
# docker-compose.yml
version: "3.9"

services:
  bot:
    build: ./services/bot
    container_name: kalshi-bot
    restart: unless-stopped
    env_file: .env
    volumes:
      - kalshi-data:/mnt/data           # Persistent data volume
      - ./services/bot/src:/app/src     # Hot reload in dev only
    depends_on:
      db:
        condition: service_healthy
    networks:
      - kalshi-net
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "5"

  data-collector:
    build: ./services/data-collector
    container_name: kalshi-collector
    restart: unless-stopped
    env_file: .env
    volumes:
      - kalshi-data:/mnt/data
    depends_on:
      db:
        condition: service_healthy
    networks:
      - kalshi-net

  trainer:
    build: ./services/trainer
    container_name: kalshi-trainer
    restart: "no"                        # Run on-demand, not continuously
    env_file: .env
    volumes:
      - kalshi-data:/mnt/data
    profiles: ["training"]               # Only starts when explicitly called
    networks:
      - kalshi-net

  db:
    image: postgres:16-alpine
    container_name: kalshi-db
    restart: unless-stopped
    env_file: .env
    environment:
      POSTGRES_DB:       ${POSTGRES_DB}
      POSTGRES_USER:     ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./services/db/init.sql:/docker-entrypoint-initdb.d/init.sql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER} -d ${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - kalshi-net

volumes:
  kalshi-data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: /mnt/kalshi-data        # Maps to DO Block Storage mount
  postgres-data:

networks:
  kalshi-net:
    driver: bridge
```

## Docker Compose Override — Production
```yaml
# docker-compose.prod.yml
# Run with: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
version: "3.9"

services:
  bot:
    volumes:
      - kalshi-data:/mnt/data           # No source mount in prod
    environment:
      BOT_ENV: production
      LOG_LEVEL: INFO
    deploy:
      resources:
        limits:
          cpus: "1.5"
          memory: 2G
        reservations:
          cpus: "0.5"
          memory: 512M

  data-collector:
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 512M

  db:
    # In production, use DO Managed DB instead — remove this service
    # and update DATABASE_URL env var to point to managed DB
    profiles: ["local-only"]
```

