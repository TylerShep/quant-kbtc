## Health Check Implementation
```python
# services/bot/src/healthcheck.py
import sys
import requests
import psycopg2
import os

def check_db():
    conn = psycopg2.connect(os.getenv("DATABASE_URL"))
    conn.close()

def check_kalshi_api():
    # Just check connectivity, not auth
    r = requests.get("https://trading-api.kalshi.com/trade-api/v2/exchange/status", timeout=5)
    r.raise_for_status()

def check_bot_heartbeat():
    # Bot writes a heartbeat timestamp to DB every 60s
    # Fail if heartbeat is older than 5 minutes
    conn = psycopg2.connect(os.getenv("DATABASE_URL"))
    cur = conn.cursor()
    cur.execute("SELECT value FROM bot_state WHERE key = 'last_heartbeat'")
    row = cur.fetchone()
    if not row:
        sys.exit(1)
    import json, datetime
    last = datetime.datetime.fromisoformat(json.loads(row[0])["timestamp"])
    age = (datetime.datetime.utcnow() - last).total_seconds()
    if age > 300:  # 5 minutes
        sys.exit(1)

if __name__ == "__main__":
    try:
        check_db()
        check_kalshi_api()
        check_bot_heartbeat()
        sys.exit(0)
    except Exception as e:
        print(f"Health check failed: {e}", file=sys.stderr)
        sys.exit(1)
```

