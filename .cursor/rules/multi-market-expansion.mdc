# Multi-Market Expansion

## Role Purpose
Defines when and how to expand from the initial BTC-only bot to additional markets (starting with ETH), without cannibalizing capital, creating correlated blow-up risk, or diluting attention before the BTC strategy is proven. Expansion is a reward for sustained BTC profitability — not a hedge against it.

## Expansion Prerequisites (Must Clear ALL Before Adding Any Market)
```python
EXPANSION_GATES = {
    # BTC bot must be mature and proven
    "btc_live_weeks":           12,     # 3 months of live BTC trading
    "btc_deployment_stage":     "standard",  # At 50%+ bankroll deployment
    "btc_rolling_sharpe_90d":   1.0,    # 90-day live Sharpe > 1.0
    "btc_max_drawdown_live":    0.15,   # No more than 15% drawdown in live period

    # New market must be independently validated
    "new_market_oos_sharpe":    1.0,    # OOS backtest Sharpe on new market
    "new_market_oos_trades":    200,    # Minimum OOS trades for significance
    "new_market_paper_weeks":   4,      # Paper trading on new market before live

    # Combined risk must stay within limits
    "max_combined_exposure":    0.15,   # BTC + ETH combined never > 15% at risk
    "max_correlated_positions": 1,      # Never long BTC and long ETH simultaneously
}

def can_expand(btc_live_stats: dict, new_market_backtest: dict) -> tuple[bool, list[str]]:
    failures = []
    for gate, threshold in EXPANSION_GATES.items():
        if gate.startswith("btc_") and btc_live_stats.get(gate.replace("btc_","")) < threshold:
            failures.append(f"BTC gate not met: {gate} = {btc_live_stats.get(gate.replace('btc_',''))} < {threshold}")
        if gate.startswith("new_market_") and new_market_backtest.get(gate.replace("new_market_","")) < threshold:
            failures.append(f"New market gate not met: {gate}")
    return len(failures) == 0, failures
```

## Market Correlation Analysis
```python
import numpy as np
from scipy import stats

def analyze_market_correlation(btc_returns: list, eth_returns: list) -> dict:
    """
    Compute correlation between BTC and ETH trade returns.
    High correlation means adding ETH adds risk, not diversification.
    Target: correlation < 0.5 for meaningful diversification benefit.
    """
    corr, p = stats.pearsonr(btc_returns, eth_returns)
    return {
        "pearson_correlation": round(corr, 3),
        "p_value":             round(p, 4),
        "diversification_benefit": corr < 0.5,
        "recommendation": (
            "PROCEED — meaningful diversification" if corr < 0.3 else
            "CAUTION — moderate correlation, reduce combined size" if corr < 0.5 else
            "DO NOT ADD — too correlated, no real diversification benefit"
        ),
    }

# BTC and ETH are typically 0.7–0.9 correlated on short timeframes.
# This means adding ETH provides limited diversification on 15-min signals.
# The primary reason to add ETH is additional trade opportunity, not risk reduction.
# Size both markets conservatively when correlation is high.
```

