## Alert Routing Implementation
```python
# alerts/manager.py

import os
import requests
import json

class AlertManager:

    def __init__(self):
        self.slack_critical   = os.getenv("SLACK_CRITICAL_WEBHOOK")
        self.slack_trading    = os.getenv("SLACK_TRADING_WEBHOOK")
        self.slack_infra      = os.getenv("SLACK_INFRA_WEBHOOK")
        self.sms_webhook      = os.getenv("SMS_ALERT_WEBHOOK")   # e.g., PagerDuty/Twilio
        self.email_webhook    = os.getenv("EMAIL_ALERT_WEBHOOK")
        self.active_alerts    = {}   # Track active alerts to prevent repeat firing

    def send(self, alert_key: str, level: str, message: str, **context):
        """Route and send an alert. Deduplicates within 15-minute windows."""

        # Deduplication: don't re-alert on the same condition every minute
        dedup_key = f"{alert_key}:{level}"
        if dedup_key in self.active_alerts:
            return   # Already alerting on this — skip

        self.active_alerts[dedup_key] = True

        # Format message with context
        formatted = message.format(**context)

        # Route by level
        if level == "CRITICAL":
            self._send_slack(self.slack_critical, formatted, level, alert_key)
            self._send_sms(formatted)
        elif level == "WARNING":
            channel = CRITICAL_ALERTS.get(alert_key, {}).get("route", ["slack_trading"])
            if "slack_infra"    in channel: self._send_slack(self.slack_infra, formatted, level, alert_key)
            if "slack_trading"  in channel: self._send_slack(self.slack_trading, formatted, level, alert_key)
            if "sms"            in channel: self._send_sms(formatted)
            if "email"          in channel: self._send_email(formatted)

        # Log all alerts
        logger.info("ALERT_SENT", alert_key=alert_key, level=level, message=formatted)

    def resolve(self, alert_key: str):
        """Send RESOLVED notification when a condition clears."""
        dedup_key_critical = f"{alert_key}:CRITICAL"
        dedup_key_warning  = f"{alert_key}:WARNING"
        was_active = dedup_key_critical in self.active_alerts or dedup_key_warning in self.active_alerts

        self.active_alerts.pop(dedup_key_critical, None)
        self.active_alerts.pop(dedup_key_warning, None)

        if was_active:
            self._send_slack(self.slack_trading, f"✅ RESOLVED: {alert_key}", "RESOLVED", alert_key)

    def _send_slack(self, webhook: str, message: str, level: str, key: str):
        emoji = {"CRITICAL": "🚨", "WARNING": "⚠️", "RESOLVED": "✅", "INFO": "ℹ️"}.get(level, "")
        try:
            requests.post(webhook, json={"text": f"{emoji} *{level}* | {key}\n{message}"}, timeout=5)
        except Exception as e:
            logger.error("ALERT_SEND_FAILED", channel="slack", error=str(e))

    def _send_sms(self, message: str):
        # Implement with PagerDuty, Twilio, or similar
        try:
            requests.post(self.sms_webhook, json={"message": message[:160]}, timeout=5)
        except Exception as e:
            logger.error("ALERT_SEND_FAILED", channel="sms", error=str(e))
```

## Alert Fatigue Prevention
```python
ANTI_FATIGUE_RULES = {
    "deduplication_window_min":    15,    # Same alert doesn't fire more than once per 15 min
    "warning_cooldown_min":        60,    # Same WARNING doesn't repeat within 1 hour
    "max_alerts_per_hour":         10,    # If > 10 alerts/hour, suppress non-criticals
    "digest_hour_utc":             8,     # INFO digest sent once daily at 8 AM UTC
    "auto_resolve_required":       True,  # All WARNING alerts must have auto-resolve path
}

def check_alert_volume(alert_log: list) -> bool:
    """Return True if alert volume is too high — suppress non-criticals."""
    recent = [a for a in alert_log if a["age_min"] < 60]
    return len(recent) > ANTI_FATIGUE_RULES["max_alerts_per_hour"]
```

## Slack Channel Structure
```
#kalshi-critical   → CRITICAL only. Every message here requires a human response.
#kalshi-trading    → Trade decisions, circuit breakers, fill rates, PnL alerts
#kalshi-infra      → Latency, disk, pipeline, WS reconnects
#kalshi-daily      → Daily digest (automated, no one needs to read immediately)
```

## Guardrails
- CRITICAL alerts must always get through — never suppress based on volume or deduplication
- Every CRITICAL must have a RESOLVED when the condition clears — no open alerts left dangling
- Never add a new alert without defining its deduplication window and auto-resolve condition
- Review alert volume monthly — if any WARNING fires > 5x/week, tune the threshold or fix the root cause
- Test alert routing quarterly: intentionally trigger each CRITICAL to confirm it actually pages
