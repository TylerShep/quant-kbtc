        "yield":        0.045,
        "liquidity":    "1-2 business days to Kalshi",
        "use_when":     "Weekly halt triggered, or during low-volume holiday periods",
    },
    "option_3": {
        "description":  "T-bill money market fund (stable, liquid)",
        "yield":        0.05,
        "liquidity":    "1-3 business days",
        "use_when":     "Large drawdown halt — park capital safely while reviewing strategy",
    },
}

def calculate_opportunity_cost(amount: float, days_parked: int, yield_rate: float) -> float:
    """What are we earning on reserves vs. what we could be making trading?"""
    reserve_return = amount * yield_rate * (days_parked / 365)
    trading_return_estimate = amount * 0.002 * days_parked  # ~0.2%/day estimate
    return trading_return_estimate - reserve_return
```

## Tech Stack Cost Management
```python
# Monthly cost tracking — every dollar of OpEx reduces net profitability
# Treasury owns cost optimization; SRE owns cost execution

MONTHLY_COST_BUDGET = {
    # Infrastructure
    "digitalocean_droplet":         24.00,   # 2vCPU/4GB
    "digitalocean_db":              15.00,   # Managed PostgreSQL
    "digitalocean_backups":          5.00,
    "digitalocean_spaces":           5.00,
    "digitalocean_block_storage":    5.00,
    "total_infrastructure":         54.00,

    # Data feeds
    "binance_api":                   0.00,   # Free tier sufficient
    "coinbase_api":                  0.00,   # Free tier sufficient
    "kalshi_api":                    0.00,   # Included with account
    "total_data":                    0.00,

    # Tooling & Services
    "alert_webhook":                 0.00,   # Free (Slack/Discord)
    "monitoring":                    0.00,   # DO monitoring included
    "total_tooling":                 0.00,

    # Total monthly OpEx
    "total_monthly":                54.00,

    # Break-even: how much must the bot make monthly to cover costs?
    "break_even_trades":    lambda daily_trades, avg_pnl_per_trade:
                            54.00 / (daily_trades * 30 * avg_pnl_per_trade),
}

def monthly_net_profit(gross_pnl: float) -> float:
    return gross_pnl - MONTHLY_COST_BUDGET["total_monthly"]

# Cost optimization levers (review quarterly):
COST_OPTIMIZATION_OPPORTUNITIES = [
    "Downgrade Droplet to 1vCPU/2GB if latency budget allows ($12/mo savings)",
    "Use DO reserved instances if running >1 year ($10/mo savings)",
    "Disable DO backups if using Spaces backup strategy ($5/mo savings)",
    "Compress ob_snapshots aggressively to reduce storage ($2/mo savings)",
]
```

## Net P&L Reporting (After All Costs)
```python
def generate_monthly_treasury_report(gross_trading_pnl: float, month: str) -> dict:
    trading_fees    = gross_trading_pnl * 0.007     # Estimated Kalshi round-trip fees (~0.7%)
    infrastructure  = MONTHLY_COST_BUDGET["total_monthly"]
    net_pnl         = gross_trading_pnl - trading_fees - infrastructure

    return {
        "month":                    month,
        "gross_trading_pnl":        round(gross_trading_pnl, 2),
        "kalshi_fees":              round(trading_fees, 2),
        "infrastructure_costs":     round(infrastructure, 2),
        "net_pnl":                  round(net_pnl, 2),
        "net_return_on_bankroll":   round(net_pnl / CAPITAL_STRUCTURE["total_capital"] * 100, 2),
        "cost_as_pct_of_gross":     round(infrastructure / gross_trading_pnl * 100, 2) if gross_trading_pnl > 0 else "N/A",
        "reserve_yield_earned":     "...",   # Interest from parked reserves
    }
```

