## Log Storage & Rotation
```python
# logging_config.py

import logging.handlers

def configure_logging(env: str):
    handlers = []

    # Rotating file handler — 50MB per file, keep 10 files
    file_handler = logging.handlers.RotatingFileHandler(
        "/mnt/kalshi-data/logs/bot.jsonl",
        maxBytes    = 50 * 1024 * 1024,   # 50MB
        backupCount = 10,
    )
    handlers.append(file_handler)

    # Console handler (Docker captures stdout → JSON logging driver)
    handlers.append(logging.StreamHandler())

    # In production: only INFO and above
    level = logging.DEBUG if env == "development" else logging.INFO

    logging.basicConfig(level=level, handlers=handlers, format="%(message)s")
```

## Log Query Patterns (For Debugging)
```bash
# --- Find all trades in the last 24 hours ---
cat /mnt/kalshi-data/logs/bot.jsonl | \
    python3 -c "
import sys, json
from datetime import datetime, timezone, timedelta
cutoff = datetime.now(timezone.utc) - timedelta(hours=24)
for line in sys.stdin:
    try:
        r = json.loads(line)
        if r.get('event') in ('POSITION_OPENED', 'POSITION_CLOSED') and \
           datetime.fromisoformat(r['timestamp']) > cutoff:
            print(json.dumps(r, indent=2))
    except: pass
"

# --- Find all signal conflicts today ---
grep 'SIGNAL_CONFLICT' /mnt/kalshi-data/logs/bot.jsonl | tail -50 | python3 -m json.tool

# --- Find all circuit breaker events ---
grep 'CIRCUIT_BREAKER' /mnt/kalshi-data/logs/bot.jsonl

# --- Check latency by component (last hour) ---
cat /mnt/kalshi-data/logs/bot.jsonl | python3 -c "
import sys, json
from collections import defaultdict
latencies = defaultdict(list)
for line in sys.stdin:
    try:
        r = json.loads(line)
        if 'latency_ms' in r:
            latencies[r.get('component','unknown')].append(r['latency_ms'])
    except: pass
for comp, vals in latencies.items():
    vals.sort()
    n = len(vals)
    print(f'{comp}: p50={vals[n//2]:.1f}ms p95={vals[int(n*0.95)]:.1f}ms max={vals[-1]:.1f}ms')
"

# --- Find all errors in last hour ---
grep '"level":"ERROR"\|"level":"CRITICAL"' /mnt/kalshi-data/logs/bot.jsonl | \
    python3 -c "
import sys, json
from datetime import datetime, timezone, timedelta
cutoff = datetime.now(timezone.utc) - timedelta(hours=1)
for line in sys.stdin:
    r = json.loads(line.strip())
    if datetime.fromisoformat(r['timestamp']) > cutoff:
        print(r['event'], '|', r.get('rejection_code',''), r.get('error',''))
"
```

