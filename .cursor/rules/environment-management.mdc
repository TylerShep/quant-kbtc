# Environment Management

## Role Purpose
The bot operates across three environments: development (local), paper (live data, fake money), and production (live data, real money). Clear separation between these environments prevents the most catastrophic class of trading bot errors — accidentally running untested code with real capital.

## Environment Definitions
```python
ENVIRONMENTS = {
    "development": {
        "description":    "Local machine, mocked Kalshi API, synthetic data",
        "kalshi_api":     "mock",           # No real API calls
        "data_source":    "local_files",    # Pre-recorded historical data
        "order_execution":"simulated",      # No real orders
        "bankroll":       "virtual",
        "logging_level":  "DEBUG",
        "alerts":         "disabled",       # Don't spam Slack during dev
        "db":             "local_postgres", # Docker DB, reset freely
    },
    "paper": {
        "description":    "Cloud server, live Kalshi data, simulated orders",
        "kalshi_api":     "live_read_only", # Reads live market data, no order submission
        "data_source":    "live",
        "order_execution":"paper_fill_model", # Realistic fill simulation
        "bankroll":       "virtual_10000",
        "logging_level":  "INFO",
        "alerts":         "slack_only",     # Alerts go to Slack, no SMS/pager
        "db":             "do_managed_paper_schema",
    },
    "production": {
        "description":    "Cloud server, live Kalshi data, real orders",
        "kalshi_api":     "live_full",      # Full read + write API access
        "data_source":    "live",
        "order_execution":"live",
        "bankroll":       "real",
        "logging_level":  "INFO",
        "alerts":         "full",           # All channels including pager/SMS
        "db":             "do_managed_prod_schema",
    },
}
```

## Environment Detection & Config Loading
```python
# config/environment.py

import os
from dataclasses import dataclass

BOT_ENV = os.getenv("BOT_ENV", "development")

@dataclass
class EnvironmentConfig:
    name:             str
    is_production:    bool
    is_paper:         bool
    use_live_api:     bool
    use_real_orders:  bool
    log_level:        str
    alert_level:      str   # "full" | "slack_only" | "disabled"
    db_schema:        str

def load_env_config() -> EnvironmentConfig:
    if BOT_ENV == "production":
        return EnvironmentConfig(
            name="production", is_production=True, is_paper=False,
            use_live_api=True, use_real_orders=True,
            log_level="INFO", alert_level="full", db_schema="prod",
        )
    elif BOT_ENV == "paper":
        return EnvironmentConfig(
            name="paper", is_production=False, is_paper=True,
            use_live_api=True, use_real_orders=False,
            log_level="INFO", alert_level="slack_only", db_schema="paper",
        )
    else:
        return EnvironmentConfig(
            name="development", is_production=False, is_paper=False,
            use_live_api=False, use_real_orders=False,
            log_level="DEBUG", alert_level="disabled", db_schema="dev",
        )

ENV = load_env_config()

# Safety check: never run real orders unless BOT_ENV is explicitly "production"
def assert_production_safe(action: str):
    if ENV.use_real_orders and BOT_ENV != "production":
        raise RuntimeError(
            f"SAFETY VIOLATION: Attempted real order ({action}) outside production env. "
            f"BOT_ENV={BOT_ENV}. This should never happen."
        )
```

## Feature Flags
```python
# config/feature_flags.py
# Use feature flags to safely test changes in production without a full deployment
# Flags can be toggled via DB or environment variable without restarting the bot

import os

class FeatureFlags:
    """
    All new features start behind a flag.
    Flag is OFF by default in production.
    Turn on in paper first, then production.
    """

    # OBI enhancements
    USE_DYNAMIC_OBI_THRESHOLDS  = os.getenv("FF_DYNAMIC_OBI",     "false") == "true"
    USE_SESSION_BASED_THRESHOLDS = os.getenv("FF_SESSION_OBI",    "false") == "true"

    # ROC enhancements
    USE_VOLUME_CONFIRMATION      = os.getenv("FF_VOLUME_CONFIRM",  "false") == "true"

    # ML model integration
    USE_ML_SIGNAL_LAYER          = os.getenv("FF_ML_SIGNALS",      "false") == "true"
    ML_SIGNAL_WEIGHT             = float(os.getenv("FF_ML_WEIGHT", "0.3"))

    # Risk adjustments
    USE_DRAWDOWN_REDUCTION       = os.getenv("FF_DD_REDUCTION",    "true")  == "true"
    USE_SESSION_SIZE_SCALING     = os.getenv("FF_SESSION_SIZING",  "false") == "true"

    # New markets
    ENABLE_ETH_MARKET            = os.getenv("FF_ETH_MARKET",      "false") == "true"

FLAGS = FeatureFlags()

